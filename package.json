{
  "name": "grant-hunter",
  "version": "0.1.0",
  "private": true,
  "description": "White-label, self-hosted grant discovery + application platform (one org per instance)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "node scripts/require-node.cjs",
    "dev": "node scripts/require-node.cjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "node scripts/require-node.cjs && tsx scripts/setup.ts",
    "onboard": "node scripts/require-node.cjs && tsx scripts/onboard.ts",
    "discover": "node scripts/require-node.cjs && tsx engine/run-discovery.ts",
    "discover:manual": "node scripts/require-node.cjs && tsx engine/run-discovery.ts --manual",
    "jobs": "node scripts/require-node.cjs && tsx engine/run-jobs.ts",
    "gate:backtest": "node scripts/require-node.cjs && tsx scripts/gate-backtest.ts",
    "seed:demo": "node scripts/require-node.cjs && tsx scripts/seed-demo.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.1",
    "modern-screenshot": "^4.7.0",
    "next": "^16.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
