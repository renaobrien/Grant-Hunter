# Anthropic API key for grant search + scoring
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. claude-haiku-4-5 is the cheap default; swap to claude-sonnet-4-6 if matching quality is poor.
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Sheet for tracking grants (see SETUP.md for schema)
SHEET_ID=
GOOGLE_KEY_FILE=./google-service-account.json

# Where to send the weekly digest. Comma-separate for multiple recipients.
RECIPIENT_EMAIL=

# Gmail account that sends the digest. App password required (not your real password).
# https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=

# Friendly From line, e.g. "SWB Grants Bot <bot@example.com>"
FROM_EMAIL=
