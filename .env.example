# Copy to .env.local and fill in. `npm run setup` also writes most of these for you.

# --- Supabase (your own project) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only: engine + API routes. NEVER expose to the browser.

# --- Anthropic (your own key) ---
ANTHROPIC_API_KEY=

# --- Notifications — all channels are OPTIONAL; pick any (or several) ---
# `npm run setup` walks you through choosing channels. Slack and Discord need
# ONLY a webhook URL entered during setup (stored in the DB, no env var here).
# Only Email and Telegram need the secrets below.

# Email (Resend): add an API key + verified From address to enable email digests.
RESEND_API_KEY=
RESEND_FROM="Grants <grants@yourdomain.com>"

# Telegram: bot token (from @BotFather) enables Telegram digests + inline rating.
# Your chat_id is entered during `npm run setup` (stored in the DB, not here).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=            # value sent as X-Telegram-Bot-Api-Secret-Token

# --- App ---
APP_BASE_URL=http://localhost:3000
DAILY_BUDGET_USD=5                  # per-instance safety cap on agent spend/day (also stored in settings)

# --- Login ---
# AUTH_DISABLED=true runs the app with NO sign-in — the default for a local
# self-host, where a login wall on your own machine is just friction. Set it to
# "false" (or remove the line) to require magic-link login.
# ⚠ NEVER set this to true on a public/hosted instance — it makes the whole app
#   open to anyone. See DEPLOY.md.
AUTH_DISABLED=true

# --- In-app feedback button (OPTIONAL) ---
# The Feedback button opens a prefilled GitHub "new issue" page — no token, no
# server. Set the target repo here to override the default (renaobrien/Grant-Hunter).
# Public value (NEXT_PUBLIC_*) by design; it's just a repo name, no secret.
NEXT_PUBLIC_FEEDBACK_REPO=          # "owner/repo" feedback issues open against
