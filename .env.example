# You usually DON'T edit this by hand: `npm run dev` opens a browser wizard
# (/connect) that writes .env.local for you; `npm run setup` (CLI) does too.
# This file is the reference for what can be set.

# --- Supabase (your own project) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only: engine + API routes. NEVER expose to the browser.

# --- Anthropic (your own key) ---
ANTHROPIC_API_KEY=

# --- Local model (Ollama) - OPTIONAL, self-hosted instances only ---
# Run the agents on a local model instead of Anthropic: free, private, no key.
# Manage this in Settings -> AI provider (which writes these vars), or set by hand.
# Caveat: local models have no web search, so discovery can't verify live pages;
# drafting, judging, profile compile, and requirements extraction work fully.
# LLM_PROVIDER=ollama                 # 'ollama' to use a local model; unset/anthropic otherwise
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1               # a pulled Ollama model; bigger instruct models follow JSON better

# --- Notifications - all channels are OPTIONAL; pick any (or several) ---
# `npm run setup` walks you through choosing channels. Slack and Discord need
# ONLY a webhook URL entered during setup (stored in the DB, no env var here).
# Only Email and Telegram need the secrets below.

# Email (Resend): add an API key + verified From address to enable email digests.
RESEND_API_KEY=
RESEND_FROM="Grants <grants@yourdomain.com>"

# Telegram: bot token (from @BotFather) enables Telegram digests + inline rating.
# Your chat_id is entered during `npm run setup` (stored in the DB, not here).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=            # value sent as X-Telegram-Bot-Api-Secret-Token

# --- App ---
APP_BASE_URL=http://localhost:3000
DAILY_BUDGET_USD=5                  # per-instance safety cap on agent spend/day (also stored in settings)

# --- Login ---
# Login is OFF by default. Locally you just open the app - no sign-in. Leave the
# next line commented for that. Set REQUIRE_LOGIN=true ONLY when hosting the app
# publicly, so magic-link sign-in (gated by your members allowlist) is enforced.
# ⚠ On a public/hosted instance you MUST set this, or anyone can reach your data.
# REQUIRE_LOGIN=true

# --- In-app feedback button (OPTIONAL) ---
# The Feedback button opens a prefilled GitHub "new issue" page - no token, no
# server. Set the target repo here to override the default (renaobrien/Grant-Hunter).
# Public value (NEXT_PUBLIC_*) by design; it's just a repo name, no secret.
NEXT_PUBLIC_FEEDBACK_REPO=          # "owner/repo" feedback issues open against
