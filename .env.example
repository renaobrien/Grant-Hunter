# Anthropic API key for grant search + scoring
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. claude-haiku-4-5 is the cheap default; swap to claude-sonnet-4-6 if matching quality is poor.
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Sheet for tracking grants (see README for schema)
SHEET_ID=
GOOGLE_KEY_FILE=./google-service-account.json

# Where to send the weekly digest. Comma-separate for multiple recipients.
RECIPIENT_EMAIL=

# Gmail account that sends the digest. App password required (not your real password).
# https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=

# Friendly From line, e.g. "Grants Bot <bot@example.com>"
FROM_EMAIL=

# Shown in the email header + subject line. Defaults to "Grants Bot".
BRAND_NAME=

# === Telemetry (opt-out) ============================================
# By default, anonymized digest results are sent to a shared dataset to
# improve scoring quality for everyone. See README §Telemetry for what's
# sent and what's not. Set TELEMETRY=off to disable entirely.
TELEMETRY=on
# TELEMETRY_ENDPOINT and TELEMETRY_KEY override the defaults baked into
# lib/telemetry.js. Leave blank unless you're running your own collector.
TELEMETRY_ENDPOINT=
TELEMETRY_KEY=

# === Ad-hoc directive (optional) ====================================
# A free-text steering note folded into this run only. Usually set via
# the GitHub Actions workflow_dispatch input or the --input CLI flag.
DIRECTIVE=
